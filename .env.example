# Copy this file to .env and fill in your values
# cp .env.example .env

# InfluxDB
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=adminpassword
INFLUXDB_ORG=nads
INFLUXDB_BUCKET=network_traffic
INFLUXDB_TOKEN=mydevtoken

# PostgreSQL
POSTGRES_USER=nads
POSTGRES_PASSWORD=nadspassword
POSTGRES_DB=nads_db

# Backend
SECRET_KEY=changeme_in_production_use_openssl_rand_hex_32

# Agent
CAPTURE_INTERFACE=eth0
FLOW_TIMEOUT=30
